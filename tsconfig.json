{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "module": "ES2020",
    "strict": true,
    "outDir": ".",
    "rootDir": "src",
    "sourceMap": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/script.ts"],
  "exclude": ["node_modules"]
}
